# ===========================
# FastAPI Configuration
# ===========================
DEBUG=false
LOG_LEVEL=INFO

# ===========================
# API Configuration
# ===========================
API_VERSION=1.0.0
API_TITLE=Sudoku Automation System
API_DESCRIPTION=AI-powered Sudoku solver with image recognition

# ===========================
# CORS Configuration
# ===========================
# Comma-separated list of allowed origins
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8000", "https://yourdomain.com"]

# ===========================
# Image Processing
# ===========================
MAX_IMAGE_SIZE_MB=10
IMAGE_TIMEOUT_SECONDS=30
MIN_IMAGE_WIDTH=300
MIN_IMAGE_HEIGHT=300

# ===========================
# Model Configuration
# ===========================
MODEL_PATH=./app/models/sudoku_digit_mlp.joblib
CONFIDENCE_THRESHOLD=0.70
DIGIT_RECOGNITION_VARIANTS=3

# ===========================
# Sudoku Solver Configuration
# ===========================
MAX_RETRIES=3
RETRY_STRATEGY=adaptive

# ===========================
# Server Configuration
# ===========================
HOST=0.0.0.0
PORT=8000
WORKERS=4

# ===========================
# Logging Configuration
# ===========================
LOG_FORMAT=json
LOG_FILE=logs/sudoku_automation.log

# ===========================
# Database (Future Use)
# ===========================
# DATABASE_URL=sqlite:///./sudoku.db

# ===========================
# Authentication (Future Use)
# ===========================
# SECRET_KEY=your-secret-key-here
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=30

# ===========================
# Email Notifications (Optional)
# ===========================
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SENDER_EMAIL=your-email@gmail.com

# ===========================
# Analytics (Optional)
# ===========================
# SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
# ANALYTICS_ENABLED=false
